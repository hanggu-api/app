generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../generated/client"
  engineType      = "wasm"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ai_embeddings {
  id              Int       @id @default(autoincrement())
  profession_id   Int
  profession_name String?
  category_id     Int?
  category_name   String?
  text            String?
  embedding       String? // SQLite doesn't support Json/Vector natively in the same way, using String
  created_at      DateTime? @default(now())
}

model ai_training_examples {
  id            Int       @id @default(autoincrement())
  profession_id Int
  category_id   Int?
  text          String
  created_at    DateTime? @default(now())

  @@index([category_id])
  @@index([profession_id])
}

model auth_users {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String // SQLite doesn't support enums
}

model categories {
  id   Int     @id @default(autoincrement())
  name String
  icon String? @default("box")
  slug String?
}

model chat_messages {
  id         BigInt    @id @default(autoincrement())
  service_id String
  sender_id  BigInt
  content    String?
  type       String?   @default("text") // Enum -> String
  sent_at    DateTime? @default(now())
  read_at    DateTime?

  service_requests service_requests @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users            @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([sender_id])
  @@index([service_id])
}

model conversations {
  id          Int       @id @default(autoincrement())
  client_id   Int
  provider_id Int
  request_id  Int?
  created_at  DateTime? @default(now())

  @@index([client_id, provider_id])
  @@index([request_id])
}

model locations {
  id         Int       @id @default(autoincrement())
  service_id Int
  lat        Float
  lng        Float
  created_at DateTime? @default(now())
}

model messages {
  id                  Int       @id @default(autoincrement())
  service_id          Int
  sender              String // Enum -> String
  text                String
  created_at          DateTime? @default(now())
  seen_by_user_at     DateTime?
  seen_by_provider_at DateTime?
}

model mission_media {
  id         Int       @id @default(autoincrement())
  mission_id Int
  user_id    Int
  kind       String
  s3_key     String
  created_at DateTime? @default(now())

  @@index([mission_id])
}

model missions {
  id          Int       @id @default(autoincrement())
  user_id     Int
  title       String
  description String?
  location    String?
  lat         Decimal?
  lng         Decimal?
  budget      Decimal?
  status      String    @default("open")
  created_at  DateTime? @default(now())
  provider_id Int?
  category    String?

  @@index([category])
  @@index([created_at])
  @@index([lat, lng])
  @@index([status])
}

model notification_devices {
  id           Int       @id @default(autoincrement())
  user_id      Int
  token        String
  platform     String?
  last_seen_at DateTime?

  @@unique([user_id, token])
  @@index([user_id])
}

model notification_registry {
  user_id      BigInt    @id
  fcm_token    String
  professions  String?
  latitude     Decimal?
  longitude    Decimal?
  is_online    Boolean   @default(false)
  last_seen_at DateTime? @default(now())

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([is_online])
  @@index([professions])
}

model notification_prefs {
  user_id       Int       @id
  allow_payment Int       @default(1)
  allow_mission Int       @default(1)
  allow_chat    Int       @default(1)
  allow_general Int       @default(1)
  updated_at    DateTime?
}

model notifications {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  title      String
  body       String?
  type       String
  related_id String?
  read_at    DateTime?
  created_at DateTime? @default(now())
  data       String? // Json -> String
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model payments {
  id                 Int       @id @default(autoincrement())
  mission_id         String
  proposal_id        Int?
  user_id            Int
  provider_id        Int?
  amount             Decimal
  currency           String    @default("BRL")
  status             String    @default("pending")
  mp_preference_id   String?
  mp_payment_id      String?
  external_ref       String?
  created_at         DateTime? @default(now())
  updated_at         DateTime?
  status_detail      String?
  payment_method_id  String?
  payer_email        String?
  collector_id       String?
  net_received       Decimal?
  fee_amount         Decimal?
  installments       Int?
  card_last_four     String?
  order_id           String?
  refund_status      String?
  refund_amount      Decimal?
  refunded_at        DateTime?
  canceled_at        DateTime?
  money_release_date DateTime?

  @@index([external_ref])
  @@index([mission_id])
  @@index([mp_payment_id])
  @@index([status])
}

model professions {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @unique
  category_id          Int?
  icon                 String?
  keywords             String?
  search_vector        String? // Json -> String
  popularity_score     Int?                   @default(0)
  service_type         String                 @default("on_site") // Enum -> String
  service_categories   service_categories?    @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task_catalog         task_catalog[]
  provider_professions provider_professions[]
}

model proposals {
  id            Int       @id @default(autoincrement())
  mission_id    Int
  user_id       Int
  price         Decimal
  deadline_days Int
  status        String    @default("sent")
  created_at    DateTime? @default(now())
}

model provider_media {
  id         Int       @id @default(autoincrement())
  user_id    Int
  kind       String
  s3_key     String
  created_at DateTime? @default(now())

  @@index([user_id])
}

model provider_penalties {
  id          Int       @id @default(autoincrement())
  provider_id Int
  request_id  Int
  reason      String?
  applied_at  DateTime? @default(now())
}

model provider_professions {
  provider_user_id BigInt
  profession_id    Int
  fixed_price      Decimal?
  hourly_rate      Decimal?
  users            users       @relation(fields: [provider_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  professions      professions @relation(fields: [profession_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([provider_user_id, profession_id])
}

model providers {
  user_id          BigInt             @id
  bio              String?
  address          String?
  rating_avg       Decimal?           @default(0.00)
  rating_count     Int?               @default(0)
  wallet_balance   Decimal?           @default(0.00)
  latitude         Decimal?
  longitude        Decimal?
  is_online        Boolean?           @default(false)
  document_type    String? // Enum -> String
  document_value   String?
  commercial_name  String?
  users            users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service_requests service_requests[]

  @@index([document_value])
}

model reviews {
  id                               Int              @id @default(autoincrement())
  service_id                       String
  reviewer_id                      BigInt
  reviewee_id                      BigInt
  rating                           Int
  comment                          String?
  created_at                       DateTime?        @default(now())
  service_requests                 service_requests @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_reviews_reviewer_idTousers users            @relation("reviews_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_reviews_reviewee_idTousers users            @relation("reviews_reviewee_idTousers", fields: [reviewee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([service_id, reviewer_id])
  @@index([reviewee_id])
  @@index([reviewer_id])
}

model service_categories {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  icon_slug        String?
  service_requests service_requests[]
  professions      professions[]
}

model service_conversations {
  id          Int       @id @default(autoincrement())
  client_id   Int
  provider_id Int
  request_id  Int?
  created_at  DateTime? @default(now())

  @@index([client_id, provider_id])
  @@index([request_id])
}

model service_edit_requests {
  id               BigInt           @id @default(autoincrement())
  service_id       String
  provider_id      BigInt
  reason           String
  description      String?
  additional_value Decimal
  platform_fee     Decimal
  images_json      String?
  video_key        String?
  status           String?          @default("pending") // Enum -> String
  created_at       DateTime?        @default(now())
  decided_at       DateTime?
  service_requests service_requests @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users            @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([provider_id])
  @@index([service_id])
}

model service_dispatches {
  id                     Int       @id @default(autoincrement())
  service_id             String
  provider_list          String // Json -> String
  status                 String    @default("active")
  current_cycle          Int       @default(1)
  current_provider_index Int       @default(0)
  history                String? // Json -> String
  last_attempt_at        DateTime?
  next_retry_at          DateTime?
  created_at             DateTime? @default(now())
  updated_at             DateTime? @updatedAt

  @@index([status])
  @@index([service_id])
}

model service_media {
  id               BigInt           @id @default(autoincrement())
  service_id       String
  media_key        String
  media_type       String // Enum -> String
  created_at       DateTime?        @default(now())
  service_requests service_requests @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([service_id])
}

model service_messages {
  id              Int       @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  content         String
  created_at      DateTime? @default(now())

  @@index([conversation_id])
}

model service_rejections {
  id          Int       @id @default(autoincrement())
  service_id  String
  provider_id Int
  created_at  DateTime? @default(now())

  @@unique([service_id, provider_id])
}

model service_requests {
  id                       String                  @id
  client_id                BigInt
  category_id              Int
  profession               String?
  provider_id              BigInt?
  description              String?
  status                   String                  @default("waiting_payment") // Enum -> String
  latitude                 Decimal?
  longitude                Decimal?
  address                  String?
  price_estimated          Decimal?
  price_upfront            Decimal?
  provider_amount          Decimal?
  scheduled_at             DateTime?
  created_at               DateTime?               @default(now())
  location_type            String?                 @default("client") // Enum -> String
  arrived_at               DateTime?
  payment_remaining_status String?                 @default("pending") // Enum -> String
  contest_reason           String?
  contest_status           String?                 @default("none") // Enum -> String
  contest_evidence         String? // Json -> String
  validation_code          String?
  proof_photo              String?
  proof_video              String?
  proof_code               String?
  completion_code          String?
  completion_requested_at  DateTime?
  status_updated_at        DateTime?               @default(now())
  completed_at             DateTime?
  appointments             appointments[]
  chat_messages            chat_messages[]
  reviews                  reviews[]
  service_edit_requests    service_edit_requests[]
  service_media            service_media[]
  users                    users                   @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service_categories       service_categories      @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  providers                providers?              @relation(fields: [provider_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  service_tasks            service_tasks[]
  transactions             transactions[]

  @@index([category_id])
  @@index([client_id])
  @@index([provider_id])
}

model service_reviews {
  id          Int       @id @default(autoincrement())
  request_id  Int
  client_id   Int
  provider_id Int
  rating      Int
  comment     String?
  created_at  DateTime? @default(now())

  @@index([provider_id])
  @@index([request_id])
}

model service_tasks {
  id               BigInt           @id @default(autoincrement())
  service_id       String
  name             String
  quantity         Decimal          @default(1.00)
  unit_price       Decimal
  subtotal         Decimal
  created_at       DateTime?        @default(now())
  service_requests service_requests @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([service_id])
}

model services {
  id          Int       @id @default(autoincrement())
  client_id   Int
  provider_id Int?
  category    String
  description String?
  status      String
  created_at  DateTime? @default(now())
}

model task_catalog {
  id            Int         @id @default(autoincrement())
  profession_id Int
  name          String
  pricing_type  String      @default("fixed") // Enum -> String
  unit_name     String?
  unit_price    Decimal
  keywords      String?
  active        Boolean?    @default(true)
  created_at    DateTime?   @default(now())
  professions   professions @relation(fields: [profession_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([profession_id])
}

model transactions {
  id               BigInt           @id @default(autoincrement())
  service_id       String
  user_id          BigInt
  amount           Decimal
  type             String // Enum -> String
  status           String?          @default("pending") // Enum -> String
  provider_ref     String?
  description      String?
  created_at       DateTime?        @default(now())
  service_requests service_requests @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([service_id])
  @@index([user_id])
}

model user_devices {
  id          BigInt    @id @default(autoincrement())
  user_id     BigInt
  token       String
  platform    String    @default("web") // Enum -> String
  last_active DateTime? @default(now())
  created_at  DateTime? @default(now())
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, token])
}

model users {
  id                                           BigInt                         @id @default(autoincrement())
  firebase_uid                                 String?                        @unique
  email                                        String                         @unique
  password_hash                                String
  full_name                                    String
  role                                         String                         @default("client") // Enum -> String
  phone                                        String?
  avatar_url                                   String?
  created_at                                   DateTime?                      @default(now())
  is_verified                                  Boolean?                       @default(false)
  avatar_blob                                  Bytes?
  avatar_mime                                  String?
  status                                       String?                        @default("active")
  appointments_appointments_client_idTousers   appointments[]                 @relation("appointments_client_idTousers")
  appointments_appointments_provider_idTousers appointments[]                 @relation("appointments_provider_idTousers")
  chat_messages                                chat_messages[]
  notifications                                notifications[]
  provider_custom_services                     provider_custom_services[]
  provider_schedule_configs                    provider_schedule_configs[]
  provider_schedule_exceptions                 provider_schedule_exceptions[]
  provider_schedules                           provider_schedules[]
  providers                                    providers?
  reviews_reviews_reviewer_idTousers           reviews[]                      @relation("reviews_reviewer_idTousers")
  reviews_reviews_reviewee_idTousers           reviews[]                      @relation("reviews_reviewee_idTousers")
  service_edit_requests                        service_edit_requests[]
  service_requests                             service_requests[]
  transactions                                 transactions[]
  user_devices                                 user_devices[]
  provider_professions                         provider_professions[]
  provider_locations                           provider_locations?
  notification_registry                        notification_registry?

  @@index([firebase_uid])
}

model provider_schedule_exceptions {
  id          Int       @id @default(autoincrement())
  provider_id BigInt
  date        DateTime
  start_time  String?
  end_time    String?
  reason      String?
  created_at  DateTime? @default(now())
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider_id, date])
  @@index([provider_id])
}

model provider_locations {
  provider_id BigInt    @id
  latitude    Decimal
  longitude   Decimal
  updated_at  DateTime? @default(now())
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([latitude, longitude])
}

model provider_schedules {
  id          Int       @id @default(autoincrement())
  provider_id BigInt
  day_of_week Int
  start_time  String
  end_time    String
  break_start String?
  break_end   String?
  is_enabled  Boolean   @default(true)
  created_at  DateTime? @default(now())
  updated_at  DateTime?
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([provider_id])
}

model provider_custom_services {
  id          Int       @id @default(autoincrement())
  provider_id BigInt
  name        String
  description String?
  duration    Int
  price       Decimal
  category    String?
  active      Boolean   @default(true)
  created_at  DateTime? @default(now())
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([provider_id])
}

model auth_otp {
  id         Int       @id @default(autoincrement())
  otp_hash   String
  expires_at DateTime
  used       Int?      @default(0)
  created_at DateTime? @default(now())

  @@map("_auth_otp")
}

model appointments {
  id                                    BigInt            @id @default(autoincrement())
  provider_id                           BigInt
  client_id                             BigInt?
  service_request_id                    String?
  start_time                            DateTime
  end_time                              DateTime
  status                                String            @default("scheduled") // Enum -> String
  notes                                 String?
  created_at                            DateTime?         @default(now())
  updated_at                            DateTime?         @default(now())
  users_appointments_client_idTousers   users?            @relation("appointments_client_idTousers", fields: [client_id], references: [id], onUpdate: NoAction)
  users_appointments_provider_idTousers users             @relation("appointments_provider_idTousers", fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service_requests                      service_requests? @relation(fields: [service_request_id], references: [id], onUpdate: NoAction)

  @@index([client_id])
  @@index([service_request_id])
  @@index([provider_id, start_time])
}

model audit_logs {
  id          BigInt    @id @default(autoincrement())
  user_id     BigInt?
  action      String
  entity_type String?
  entity_id   String?
  details     String?
  ip_address  String?
  user_agent  String?
  created_at  DateTime? @default(now())

  @@index([action])
  @@index([created_at])
  @@index([user_id])
}

model provider_schedule_configs {
  id            Int       @id @default(autoincrement())
  provider_id   BigInt
  day_of_week   Int
  start_time    DateTime
  end_time      DateTime
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())
  lunch_start   DateTime?
  lunch_end     DateTime?
  slot_duration Int?      @default(30)
  users         users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider_id, day_of_week])
}

model system_settings {
  key_name    String    @id
  value       String? // Json -> String
  description String?
  updated_at  DateTime? @default(now())
}
