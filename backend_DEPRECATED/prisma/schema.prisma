generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ai_embeddings {
  id              Int       @id @default(autoincrement())
  profession_id   Int
  profession_name String?
  category_id     Int?
  category_name   String?
  text            String?
  embedding       Json?
  created_at      DateTime? @default(now()) @db.Timestamp(0)
}

model ai_training_examples {
  id            Int       @id @default(autoincrement())
  profession_id Int
  category_id   Int?
  text          String    @db.VarChar(1000)
  created_at    DateTime? @default(now()) @db.Timestamp(0)

  @@index([category_id])
  @@index([profession_id])
}

model auth_users {
  id       Int             @id @default(autoincrement())
  email    String          @unique
  password String
  role     auth_users_role
}

model categories {
  id   Int     @id @default(autoincrement())
  name String
  icon String? @default("box") @db.VarChar(50)
  slug String?
}

model chat_messages {
  id               BigInt              @id @default(autoincrement())
  service_id       String              @db.VarChar(36)
  sender_id        BigInt
  content          String?
  type             chat_messages_type? @default(text)
  sent_at          DateTime?           @default(now()) @db.Timestamp(0)
  read_at          DateTime?           @db.Timestamp(0)
  service_requests service_requests    @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_messages_ibfk_1_fkey")
  users            users               @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_messages_ibfk_2_fkey")

  @@index([sender_id])
  @@index([service_id])
}

model conversations {
  id          Int       @id @default(autoincrement())
  client_id   Int
  provider_id Int
  request_id  Int?
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([client_id, provider_id], map: "conversations_idx_cp_idx")
  @@index([request_id], map: "conversations_idx_req_idx")
}

model locations {
  id         Int       @id @default(autoincrement())
  service_id Int
  lat        Float
  lng        Float
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model messages {
  id                  Int             @id @default(autoincrement())
  service_id          Int
  sender              messages_sender
  text                String
  created_at          DateTime?       @default(now()) @db.Timestamp(0)
  seen_by_user_at     DateTime?       @db.Timestamp(0)
  seen_by_provider_at DateTime?       @db.Timestamp(0)
}

model mission_media {
  id         Int       @id @default(autoincrement())
  mission_id Int
  user_id    Int
  kind       String    @db.VarChar(16)
  s3_key     String    @db.VarChar(512)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  @@index([mission_id], map: "mission_media_idx_mission_idx")
}

model missions {
  id          Int       @id @default(autoincrement())
  user_id     Int
  title       String
  description String?
  location    String?
  lat         Decimal?  @db.Decimal(9, 6)
  lng         Decimal?  @db.Decimal(9, 6)
  budget      Decimal?  @db.Decimal(10, 2)
  status      String    @default("open") @db.VarChar(32)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  provider_id Int?
  category    String?   @db.VarChar(64)

  @@index([category], map: "missions_idx_category_idx")
  @@index([created_at], map: "missions_idx_created_idx")
  @@index([lat, lng], map: "missions_idx_geo_idx")
  @@index([status], map: "missions_idx_status_idx")
}

model notification_devices {
  id           Int       @id @default(autoincrement())
  user_id      Int
  token        String    @db.VarChar(256)
  platform     String?   @db.VarChar(32)
  last_seen_at DateTime? @db.Timestamp(0)

  @@unique([user_id, token], map: "notification_devices_uniq_user_token_key")
  @@index([user_id], map: "notification_devices_idx_user_idx")
}

model notification_registry {
  user_id      BigInt    @id
  fcm_token    String    @db.VarChar(512)
  professions  String?   @db.VarChar(1000)
  latitude     Decimal?  @db.Decimal(10, 8)
  longitude    Decimal?  @db.Decimal(11, 8)
  is_online    Boolean   @default(false)
  last_seen_at DateTime? @default(now()) @db.Timestamp(0)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([is_online])
  @@index([professions])
}

model notification_prefs {
  user_id       Int       @id
  allow_payment Int       @default(1) @db.SmallInt
  allow_mission Int       @default(1) @db.SmallInt
  allow_chat    Int       @default(1) @db.SmallInt
  allow_general Int       @default(1) @db.SmallInt
  updated_at    DateTime? @db.Timestamp(0)
}

model notifications {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  title      String
  body       String?
  type       String    @db.VarChar(50)
  related_id String?
  read_at    DateTime? @db.Timestamp(0)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  data       Json?
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_ibfk_1_fkey")

  @@index([user_id])
}

model payments {
  id                 Int       @id @default(autoincrement())
  mission_id         String    @db.VarChar(36)
  proposal_id        Int?
  user_id            Int
  provider_id        Int?
  amount             Decimal   @db.Decimal(10, 2)
  currency           String    @default("BRL") @db.VarChar(8)
  status             String    @default("pending") @db.VarChar(32)
  mp_preference_id   String?   @db.VarChar(64)
  mp_payment_id      String?   @db.VarChar(64)
  external_ref       String?   @db.VarChar(128)
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  status_detail      String?   @db.VarChar(64)
  payment_method_id  String?   @db.VarChar(32)
  payer_email        String?
  collector_id       String?   @db.VarChar(32)
  net_received       Decimal?  @db.Decimal(10, 2)
  fee_amount         Decimal?  @db.Decimal(10, 2)
  installments       Int?
  card_last_four     String?   @db.VarChar(8)
  order_id           String?   @db.VarChar(64)
  refund_status      String?   @db.VarChar(32)
  refund_amount      Decimal?  @db.Decimal(10, 2)
  refunded_at        DateTime? @db.Timestamp(0)
  canceled_at        DateTime? @db.Timestamp(0)
  money_release_date DateTime? @db.Timestamp(0)

  @@index([external_ref], map: "payments_idx_external_idx")
  @@index([mission_id], map: "payments_idx_mission_idx")
  @@index([mp_payment_id], map: "payments_idx_payment_id_idx")
  @@index([status], map: "payments_idx_status_idx")
}

model professions {
  id               Int                      @id @default(autoincrement())
  name             String                   @unique(map: "professions_uniq_professions_name_key") @db.VarChar(128)
  category_id      Int?
  icon             String?                  @db.VarChar(64)
  keywords         String?
  search_vector    Json?
  popularity_score Int?                     @default(0)
  service_type     professions_service_type @default(on_site)
  service_categories service_categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "professions_category_id_fkey")
  task_catalog     task_catalog[]
  provider_professions provider_professions[]
}

model proposals {
  id            Int       @id @default(autoincrement())
  mission_id    Int
  user_id       Int
  price         Decimal   @db.Decimal(10, 2)
  deadline_days Int
  status        String    @default("sent") @db.VarChar(20)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
}

model provider_media {
  id         Int       @id @default(autoincrement())
  user_id    Int
  kind       String    @db.VarChar(16)
  s3_key     String    @db.VarChar(512)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  @@index([user_id], map: "provider_media_idx_user_idx")
}

model provider_penalties {
  id          Int       @id @default(autoincrement())
  provider_id Int
  request_id  Int
  reason      String?
  applied_at  DateTime? @default(now()) @db.Timestamp(0)
}

model provider_professions {
  provider_user_id BigInt
  profession_id    Int
  fixed_price      Decimal? @db.Decimal(10, 2)
  hourly_rate      Decimal? @db.Decimal(10, 2)
  users            users    @relation(fields: [provider_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_professions_ibfk_1_fkey")
  professions      professions @relation(fields: [profession_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_professions_ibfk_2_fkey")

  @@id([provider_user_id, profession_id])
}

model providers {
  user_id          BigInt                   @id
  bio              String?
  address          String?
  rating_avg       Decimal?                 @default(0.00) @db.Decimal(3, 2)
  rating_count     Int?                     @default(0)
  wallet_balance   Decimal?                 @default(0.00) @db.Decimal(10, 2)
  latitude         Decimal?                 @db.Decimal(10, 8)
  longitude        Decimal?                 @db.Decimal(11, 8)
  is_online        Boolean?                 @default(false)
  document_type    providers_document_type?
  document_value   String?                  @db.VarChar(20)
  commercial_name  String?                  @db.VarChar(100)
  users            users                    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "providers_ibfk_1_fkey")
  service_requests service_requests[]

  @@index([document_value], map: "providers_idx_providers_document_idx")
}

model reviews {
  id                               Int              @id @default(autoincrement())
  service_id                       String           @db.Char(36)
  reviewer_id                      BigInt
  reviewee_id                      BigInt
  rating                           Int
  comment                          String?
  created_at                       DateTime?        @default(now()) @db.Timestamp(0)
  service_requests                 service_requests @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_ibfk_1_fkey")
  users_reviews_reviewer_idTousers users            @relation("reviews_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_ibfk_2_fkey")
  users_reviews_reviewee_idTousers users            @relation("reviews_reviewee_idTousers", fields: [reviewee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_ibfk_3_fkey")

  @@unique([service_id, reviewer_id], map: "reviews_unique_review_key")
  @@index([reviewee_id])
  @@index([reviewer_id])
}

model service_categories {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(50)
  icon_slug        String?            @db.VarChar(50)
  service_requests service_requests[]
  professions      professions[]
}

model service_conversations {
  id          Int       @id @default(autoincrement())
  client_id   Int
  provider_id Int
  request_id  Int?
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([client_id, provider_id], map: "service_conversations_idx_cp2_idx")
  @@index([request_id], map: "service_conversations_idx_req2_idx")
}

model service_edit_requests {
  id               BigInt                        @id @default(autoincrement())
  service_id       String                        @db.VarChar(36)
  provider_id      BigInt
  reason           String
  description      String?
  additional_value Decimal                       @db.Decimal(10, 2)
  platform_fee     Decimal                       @db.Decimal(10, 2)
  images_json      String?
  video_key        String?
  status           service_edit_requests_status? @default(pending)
  created_at       DateTime?                     @default(now()) @db.Timestamp(0)
  decided_at       DateTime?                     @db.Timestamp(0)
  service_requests service_requests              @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "service_edit_requests_ibfk_1_fkey")
  users            users                         @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "service_edit_requests_ibfk_2_fkey")

  @@index([provider_id])
  @@index([service_id])
}

model service_dispatches {
  id                     Int       @id @default(autoincrement())
  service_id             String    @db.VarChar(36)
  provider_list          Json
  status                 String    @default("active") @db.VarChar(20)
  current_cycle          Int       @default(1)
  current_provider_index Int       @default(0)
  history                Json?
  last_attempt_at        DateTime? @db.Timestamp(0)
  next_retry_at          DateTime? @db.Timestamp(0)
  created_at             DateTime? @default(now()) @db.Timestamp(0)
  updated_at             DateTime? @updatedAt @db.Timestamp(0)

  @@index([status], map: "service_dispatches_idx_service_dispatches_status_idx")
  @@index([service_id], map: "service_dispatches_idx_service_dispatches_service_id_idx")
}

model service_media {
  id               BigInt                   @id @default(autoincrement())
  service_id       String                   @db.VarChar(36)
  media_key        String
  media_type       service_media_media_type
  created_at       DateTime?                @default(now()) @db.Timestamp(0)
  service_requests service_requests         @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "service_media_ibfk_1_fkey")

  @@index([service_id])
}

model service_messages {
  id              Int       @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  content         String
  created_at      DateTime? @default(now()) @db.Timestamp(0)

  @@index([conversation_id], map: "service_messages_idx_conv2_idx")
}

model service_rejections {
  id          Int       @id @default(autoincrement())
  service_id  String    @db.VarChar(36)
  provider_id Int
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@unique([service_id, provider_id], map: "service_rejections_unique_rejection_key")
}

model service_requests {
  id                       String                                     @id @db.VarChar(36)
  client_id                BigInt
  category_id              Int
  profession               String?                                    @db.VarChar(128)
  provider_id              BigInt?
  description              String?
  status                   service_requests_status                    @default(waiting_payment)
  latitude                 Decimal?                                   @db.Decimal(10, 8)
  longitude                Decimal?                                   @db.Decimal(11, 8)
  address                  String?
  price_estimated          Decimal?                                   @db.Decimal(10, 2)
  price_upfront            Decimal?                                   @db.Decimal(10, 2)
  provider_amount          Decimal?                                   @db.Decimal(10, 2)
  scheduled_at             DateTime?                                  @db.Timestamp(0)
  created_at               DateTime?                                  @default(now()) @db.Timestamp(0)
  location_type            service_requests_location_type?            @default(client)
  arrived_at               DateTime?                                  @db.Timestamp(0)
  payment_remaining_status service_requests_payment_remaining_status? @default(pending)
  contest_reason           String?
  contest_status           service_requests_contest_status?           @default(none)
  contest_evidence         Json?
  validation_code          String?                                    @db.VarChar(10)
  proof_photo              String?
  proof_video              String?
  proof_code               String?                                    @db.VarChar(10)
  completion_code          String?                                    @db.VarChar(6)
  completion_requested_at  DateTime?                                  @db.Timestamp(0)
  status_updated_at        DateTime?                                  @default(now()) @db.Timestamp(0)
  completed_at             DateTime?                                  @db.Timestamp(0)
  appointments             appointments[]
  chat_messages            chat_messages[]
  reviews                  reviews[]
  service_edit_requests    service_edit_requests[]
  service_media            service_media[]
  users                    users                                      @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "service_requests_ibfk_1_fkey")
  service_categories       service_categories                         @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "service_requests_ibfk_2_fkey")
  providers                providers?                                 @relation(fields: [provider_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "service_requests_ibfk_3_fkey")
  service_tasks            service_tasks[]
  transactions             transactions[]

  @@index([category_id])
  @@index([client_id])
  @@index([provider_id])
}

model service_reviews {
  id          Int       @id @default(autoincrement())
  request_id  Int
  client_id   Int
  provider_id Int
  rating      Int
  comment     String?
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([provider_id], map: "service_reviews_idx_provider_idx")
  @@index([request_id], map: "service_reviews_idx_req2_idx")
}

model service_tasks {
  id               BigInt           @id @default(autoincrement())
  service_id       String           @db.VarChar(36)
  name             String
  quantity         Decimal          @default(1.00) @db.Decimal(10, 2)
  unit_price       Decimal          @db.Decimal(10, 2)
  subtotal         Decimal          @db.Decimal(10, 2)
  created_at       DateTime?        @default(now()) @db.Timestamp(0)
  service_requests service_requests @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "service_tasks_ibfk_1_fkey")

  @@index([service_id], map: "service_tasks_idx_service_tasks_service_idx")
}

model services {
  id          Int       @id @default(autoincrement())
  client_id   Int
  provider_id Int?
  category    String
  description String?
  status      String    @db.VarChar(32)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
}

model task_catalog {
  id            Int                       @id @default(autoincrement())
  profession_id Int
  name          String
  pricing_type  task_catalog_pricing_type @default(fixed)
  unit_name     String?                   @db.VarChar(64)
  unit_price    Decimal                   @db.Decimal(10, 2)
  keywords      String?                   @db.VarChar(1000)
  active        Boolean?                  @default(true)
  created_at    DateTime?                 @default(now()) @db.Timestamp(0)
  professions   professions               @relation(fields: [profession_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "task_catalog_ibfk_1_fkey")

  @@index([profession_id], map: "task_catalog_idx_task_catalog_profession_idx")
}

model transactions {
  id               BigInt               @id @default(autoincrement())
  service_id       String               @db.VarChar(36)
  user_id          BigInt
  amount           Decimal              @db.Decimal(10, 2)
  type             transactions_type
  status           transactions_status? @default(pending)
  provider_ref     String?
  description      String?
  created_at       DateTime?            @default(now()) @db.Timestamp(0)
  service_requests service_requests     @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_ibfk_1_fkey")
  users            users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_ibfk_2_fkey")

  @@index([service_id])
  @@index([user_id])
}

model user_devices {
  id          BigInt                @id @default(autoincrement())
  user_id     BigInt
  token       String                @db.VarChar(512)
  platform    user_devices_platform @default(web)
  last_active DateTime?             @default(now()) @db.Timestamp(0)
  created_at  DateTime?             @default(now()) @db.Timestamp(0)
  users       users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_devices_ibfk_1_fkey")

  @@unique([user_id, token], map: "user_devices_idx_user_token_key")
}

model users {
  id                                           BigInt                         @id @default(autoincrement())
  firebase_uid                                 String?                        @unique @db.VarChar(128)
  email                                        String                         @unique
  password_hash                                String
  full_name                                    String                         @db.VarChar(100)
  role                                         users_role                     @default(client)
  phone                                        String?                        @db.VarChar(20)
  avatar_url                                   String?
  created_at                                   DateTime?                      @default(now()) @db.Timestamp(0)
  is_verified                                  Boolean?                       @default(false)
  avatar_blob                                  Bytes?
  avatar_mime                                  String?                        @db.VarChar(64)
  status                                       String?                        @default("active") @db.VarChar(20)
  appointments_appointments_client_idTousers   appointments[]                 @relation("appointments_client_idTousers")
  appointments_appointments_provider_idTousers appointments[]                 @relation("appointments_provider_idTousers")
  chat_messages                                chat_messages[]
  notifications                                notifications[]
  notification_logs                            notification_logs[]
  provider_custom_services                     provider_custom_services[]
  provider_schedule_configs                    provider_schedule_configs[]
  provider_schedule_exceptions                 provider_schedule_exceptions[]
  provider_schedules                           provider_schedules[]
  providers                                    providers?
  reviews_reviews_reviewer_idTousers           reviews[]                      @relation("reviews_reviewer_idTousers")
  reviews_reviews_reviewee_idTousers           reviews[]                      @relation("reviews_reviewee_idTousers")
  service_edit_requests                        service_edit_requests[]
  service_requests                             service_requests[]
  transactions                                 transactions[]
  user_devices                                 user_devices[]
  provider_professions                         provider_professions[]
  provider_locations                           provider_locations?
  notification_registry                        notification_registry?

  @@index([firebase_uid], map: "users_idx_firebase_uid_idx")
}

model provider_schedule_exceptions {
  id          Int       @id @default(autoincrement())
  provider_id BigInt
  date        DateTime  @db.Date
  start_time  String?   @db.VarChar(5)
  end_time    String?   @db.VarChar(5)
  reason      String?
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_schedule_exceptions_ibfk_1_fkey")

  @@unique([provider_id, date], map: "provider_schedule_exceptions_uniq_provider_date_key")
  @@index([provider_id], map: "provider_schedule_exceptions_i_a68b3dd3_idx")
}

model provider_locations {
  provider_id BigInt    @id
  latitude    Decimal   @db.Decimal(10, 8)
  longitude   Decimal   @db.Decimal(11, 8)
  updated_at  DateTime? @default(now()) @db.Timestamp(0)
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_locations_ibfk_1_fkey")

  @@index([latitude, longitude], map: "provider_locations_idx_lat_lng_idx")
}

model provider_schedules {
  id          Int       @id @default(autoincrement())
  provider_id BigInt
  day_of_week Int
  start_time  String    @db.VarChar(5)
  end_time    String    @db.VarChar(5)
  break_start String?   @db.VarChar(5)
  break_end   String?   @db.VarChar(5)
  is_enabled  Boolean   @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_schedules_ibfk_1_fkey")

  @@index([provider_id], map: "provider_schedules_idx_provider_schedules_provider_idx")
}

model provider_custom_services {
  id          Int       @id @default(autoincrement())
  provider_id BigInt
  name        String
  description String?
  duration    Int
  price       Decimal   @db.Decimal(10, 2)
  category    String?   @db.VarChar(50)
  active      Boolean   @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  users       users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_custom_services_ibfk_1_fkey")

  @@index([provider_id], map: "provider_custom_services_idx_p_9593d06f_idx")
}

model auth_otp {
  id         Int       @id @default(dbgenerated("nextval('_auth_otp_id_seq'::regclass)"))
  otp_hash   String
  expires_at DateTime  @db.Timestamp(0)
  used       Int?      @default(0) @db.SmallInt
  created_at DateTime? @default(now()) @db.Timestamp(0)

  @@map("_auth_otp")
}

model appointments {
  id                                    BigInt              @id @default(autoincrement())
  provider_id                           BigInt
  client_id                             BigInt?
  service_request_id                    String?             @db.VarChar(36)
  start_time                            DateTime            @db.Timestamp(0)
  end_time                              DateTime            @db.Timestamp(0)
  status                                appointments_status @default(scheduled)
  notes                                 String?
  created_at                            DateTime?           @default(now()) @db.Timestamp(0)
  updated_at                            DateTime?           @default(now()) @db.Timestamp(0)
  users_appointments_client_idTousers   users?              @relation("appointments_client_idTousers", fields: [client_id], references: [id], onUpdate: NoAction, map: "appointments_fk_app_client_fkey")
  users_appointments_provider_idTousers users               @relation("appointments_provider_idTousers", fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "appointments_fk_app_provider_fkey")
  service_requests                      service_requests?   @relation(fields: [service_request_id], references: [id], onUpdate: NoAction, map: "appointments_fk_app_service_fkey")

  @@index([client_id], map: "appointments_fk_app_client_idx")
  @@index([service_request_id], map: "appointments_fk_app_service_idx")
  @@index([provider_id, start_time], map: "appointments_idx_provider_date_idx")
}

model notification_templates {
  id                String              @id
  title             String
  body              String
  type              String
  created_at        DateTime?           @default(now()) @db.Timestamp(0)
  updated_at        DateTime?           @default(now()) @db.Timestamp(0)
  notification_logs notification_logs[]
}

model notification_logs {
  id          Int                     @id @default(autoincrement())
  user_id     BigInt
  user_type   String
  template_id String?
  title       String
  body        String
  data        String?
  is_read     Boolean?                @default(false)
  sent_at     DateTime?               @default(now()) @db.Timestamp(0)
  read_at     DateTime?               @db.Timestamp(0)
  users       users                   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  templates   notification_templates? @relation(fields: [template_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@index([template_id])
}

model audit_logs {
  id          BigInt    @id @default(autoincrement())
  user_id     BigInt?
  action      String    @db.VarChar(100)
  entity_type String?   @db.VarChar(50)
  entity_id   String?   @db.VarChar(100)
  details     String?
  ip_address  String?   @db.VarChar(45)
  user_agent  String?
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([action])
  @@index([created_at])
  @@index([user_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model provider_schedule_configs {
  id            Int       @id @default(autoincrement())
  provider_id   BigInt
  day_of_week   Int       @db.SmallInt
  start_time    DateTime  @db.Time(0)
  end_time      DateTime  @db.Time(0)
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
  lunch_start   DateTime? @db.Time(0)
  lunch_end     DateTime? @db.Time(0)
  slot_duration Int?      @default(30)
  users         users     @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provider_schedule_configs_fk_sched_provider_fkey")

  @@unique([provider_id, day_of_week], map: "provider_schedule_configs_uniq_provider_day_key")
  @@unique([provider_id, day_of_week], map: "provider_schedule_configs_unique_provider_day_key")
}

model system_settings {
  key_name    String    @id @db.VarChar(50)
  value       Json?
  description String?
  updated_at  DateTime? @default(now()) @db.Timestamp(0)
}

