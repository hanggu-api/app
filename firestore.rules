rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ✅ service_requests: Cliente e Prestador podem ler seus próprios serviços
    match /service_requests/{serviceId} {
      allow read: if request.auth != null && (
        // Cliente: pode ler se for o client_id do serviço
        get(/databases/$(database)/documents/service_requests/$(serviceId)).data.client_id == request.auth.uid ||
        // Prestador: pode ler se for o provider_id do serviço  
        get(/databases/$(database)/documents/service_requests/$(serviceId)).data.provider_id == request.auth.uid
      );
      allow write: if false; // Somente backend escreve
    }
    
    // ✅ notifications: Usuário pode ler suas próprias notificações
    match /notifications/{userId}/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ✅ chats: Participantes do chat podem ler/escrever
    match /chats/{serviceId}/messages/{messageId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/service_requests/$(serviceId)).data.client_id == request.auth.uid ||
        get(/databases/$(database)/documents/service_requests/$(serviceId)).data.provider_id == request.auth.uid
      );
    }
    
    // ❌ Bloquear acesso não autorizado por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
