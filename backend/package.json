  "scripts": {
    "start": "node -r ts-node/register/transpile-only ./src/server.ts",
    "build": "tsc",
    "start:dist": "node ./dist/server.js",
    "pm2:start:ecosystem": "pm2 start ecosystem.config.js --only conserta-api",
    "pm2:start:dev": "pm2 start ecosystem.config.js --only conserta-api-dev",
    "pm2:reload:ecosystem": "pm2 reload ecosystem.config.js --only conserta-api --update-env",
    "start:prod": "npm run build && npm run pm2:start:ecosystem && pm2 save",
    "pm2:start": "pm2 start --name conserta-api -- node -r ts-node/register/transpile-only ./src/server.ts",
    "pm2:restart": "pm2 reload conserta-api --update-env",
    "pm2:stop": "pm2 stop conserta-api",
    "pm2:status": "pm2 status conserta-api",
    "pm2:logs": "pm2 logs conserta-api --lines 100",
    "pm2:start:dist": "pm2 start dist/server.js --name conserta-api",
    "migrate": "node -r ts-node/register ./src/database/migrate.ts",
    "simulate": "node -r ts-node/register ./src/simulation.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
