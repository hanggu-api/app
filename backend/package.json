    "start:prod": "node ./dist/src/server.js",
    "pm2:start": "pm2 start --name conserta-api -- node ./dist/src/server.js",
    "pm2:restart": "pm2 reload conserta-api --update-env",
    "pm2:stop": "pm2 stop conserta-api",
    "pm2:status": "pm2 status conserta-api",
    "pm2:logs": "pm2 logs conserta-api --lines 100",
    "pm2:start:dist": "pm2 start dist/server.js --name conserta-api",
    "migrate": "node ./dist/database/migrate.js",
    "aplicar-catalogo": "node ./dist/database/migrate.js --catalog-only",
    "simulate": "node ./dist/src/simulation.js",
    "gerar-catalogo": "node ./dist/ai/prosisao.js",
    "reset:profissoes": "node ./dist/database/resetProfessions.js",
    "test": "echo \"Error: no test specified\" && exit 1"
